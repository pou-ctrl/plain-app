    <string name="dlna_receiver_description">இயக்கப்படும்போது, அதே Wi-Fi நெட்வொர்க்கில் உள்ள PlainApp இந்த சாதனத்தில் வீடியோ மற்றும் இசையை ஸ்ட்ரீம் செய்யலாம்</string>

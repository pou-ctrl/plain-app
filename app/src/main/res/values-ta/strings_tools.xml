    <string name="dlna_receiver_step1_title">அதே Wi-Fi-ல் இணைக்கவும்</string>
    <string name="dlna_receiver_step1_desc">இரண்டு சாதனங்களும் ஒரே Wi-Fi நெட்வொர்க்கில் இணைக்கப்பட்டுள்ளதை உறுதிப்படுத்தவும்</string>
    <string name="dlna_receiver_step2_title">PlainApp திறக்கவும்</string>
    <string name="dlna_receiver_step2_desc">மற்ற சாதனத்தில் PlainApp திறந்து, இயக்க விரும்பும் வீடியோ அல்லது இசையை கண்டறியவும்</string>
    <string name="dlna_receiver_step3_title">ஸ்ட்ரீம் செய்யவும்</string>
    <string name="dlna_receiver_step3_desc">ஸ்ட்ரீம் ஐகானை தட்டி, பட்டியலில் இருந்து "%1$s" தேர்வு செய்யவும், இயக்கம் தொடங்கும்</string>
    <string name="dlna_receiver_protocol_note">DLNA / UPnP நெறிமுறைகளை ஆதரிக்கிறது, VLC, Kodi மற்றும் பிற பிரபலமான ஸ்ட்ரீமிங் பயன்பாடுகளுடன் இணக்கமானது</string>
